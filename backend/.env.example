# Local memory vectorization (ONNX Runtime + Qdrant Docker)
EMBEDDING_PROVIDER=onnx
EMBEDDING_MODEL_PATH=./onnx/model.onnx
EMBEDDING_TOKENIZER_PATH=./onnx/tokenizer.json
